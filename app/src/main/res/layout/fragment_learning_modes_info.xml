<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FDFDFD"
        android:orientation="vertical">

        <!-- Основной тулбар -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorPrimarySurface"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:title="Режимы обучения" />

        <!-- Контент с прокруткой -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Введение -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Выбор стратегии обучения"
                            android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Каждый режим оптимизирован под разные цели и сроки обучения. Выберите подходящий вариант для максимальной эффективности."
                            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                            android:textColor="@color/material_on_surface_emphasis_medium" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Фундаментальное обучение -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:id="@+id/fundamentalTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Фундаментальное обучение"
                            android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/fundamentalDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Глубокое усвоение материала на долгий срок с оптимальной эффективностью"
                            android:textAppearance="@style/TextAppearance.Material3.BodyMedium" />

                        <!-- Интервалы в красивом контейнере -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            app:cardBackgroundColor="@color/purple_50"
                            app:cardCornerRadius="8dp"
                            app:cardElevation="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="16dp">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="График повторений"
                                    android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/fundamentalIntervals"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="1 день → 3 дня → 1 неделя → 2 недели → 1 месяц → 3 месяца"
                                    android:textAppearance="@style/TextAppearance.Material3.BodyMedium" />

                            </LinearLayout>

                        </com.google.android.material.card.MaterialCardView>

                        <!-- Эффективность -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Эффективность:"
                                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/fundamentalEffectiveness"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:layout_weight="1"
                                android:text="80-90% через 6 месяцев"
                                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                                android:textColor="@color/green_600" />

                        </LinearLayout>

                        <!-- Случаи использования -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Рекомендуется для:"
                            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/fundamentalUseCases"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="• Подготовка к экзаменам\n• Изучение профессиональных навыков\n• Иностранные языки\n• Фундаментальные дисциплины"
                            android:textAppearance="@style/TextAppearance.Material3.BodyMedium" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Подготовка к событию -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:id="@+id/eventPrepTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Подготовка к событию"
                            android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/eventPrepDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Быстрое запоминание информации к конкретному сроку"
                            android:textAppearance="@style/TextAppearance.Material3.BodyMedium" />

                        <!-- Интервалы в красивом контейнере -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            app:cardBackgroundColor="@color/orange_50"
                            app:cardCornerRadius="8dp"
                            app:cardElevation="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="16dp">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="График повторений"
                                    android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/eventPrepIntervals"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="1 час → 6 часов → 1 день → 2 дня → 4 дня → 1 неделя"
                                    android:textAppearance="@style/TextAppearance.Material3.BodyMedium" />

                            </LinearLayout>

                        </com.google.android.material.card.MaterialCardView>

                        <!-- Эффективность -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Эффективность:"
                                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/eventPrepEffectiveness"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:layout_weight="1"
                                android:text="40-60% через 1 месяц"
                                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                                android:textColor="@color/orange_600" />

                        </LinearLayout>

                        <!-- Случаи использования -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Рекомендуется для:"
                            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/eventPrepUseCases"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="• Срочная подготовка к зачету\n• Выступление с презентацией\n• Временное запоминание фактов\n• Краткосрочные проекты"
                            android:textAppearance="@style/TextAppearance.Material3.BodyMedium" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Сравнительная таблица -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Сравнение режимов"
                            android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                            android:textStyle="bold" />

                        <!-- Таблица сравнения -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:orientation="vertical">

                            <!-- Заголовок таблицы -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@color/purple_100"
                                android:orientation="horizontal"
                                android:padding="12dp">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Критерий"
                                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:gravity="center"
                                    android:text="Фундаментальное"
                                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:gravity="center"
                                    android:text="К событию"
                                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                    android:textStyle="bold" />

                            </LinearLayout>

                            <!-- Строки таблицы -->
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="@color/gray_200" />

                            <!-- Эффективность -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:padding="12dp">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Долговременность"
                                    android:textAppearance="@style/TextAppearance.Material3.BodySmall" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:gravity="center"
                                    android:text="80-90%"
                                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                    android:textColor="@color/green_600" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:gravity="center"
                                    android:text="40-60%"
                                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                    android:textColor="@color/orange_600" />

                            </LinearLayout>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="@color/gray_100" />

                            <!-- Скорость -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:padding="12dp">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Скорость обучения"
                                    android:textAppearance="@style/TextAppearance.Material3.BodySmall" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:gravity="center"
                                    android:text="Медленнее"
                                    android:textAppearance="@style/TextAppearance.Material3.BodySmall" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:gravity="center"
                                    android:text="Быстрее"
                                    android:textAppearance="@style/TextAppearance.Material3.BodySmall" />

                            </LinearLayout>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="@color/gray_100" />

                            <!-- Время на карточку -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:padding="12dp">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Время на карточку"
                                    android:textAppearance="@style/TextAppearance.Material3.BodySmall" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:gravity="center"
                                    android:text="30-60 сек"
                                    android:textAppearance="@style/TextAppearance.Material3.BodySmall" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:gravity="center"
                                    android:text="15-30 сек"
                                    android:textAppearance="@style/TextAppearance.Material3.BodySmall" />

                            </LinearLayout>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="@color/gray_100" />

                            <!-- Рекомендации -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:padding="12dp">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Рекомендуется"
                                    android:textAppearance="@style/TextAppearance.Material3.BodySmall" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:gravity="center"
                                    android:text="Экзамены, навыки"
                                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                    android:textColor="@color/purple_600" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:gravity="center"
                                    android:text="Зачеты, события"
                                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                    android:textColor="@color/orange_600" />

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Научное обоснование -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Научное обоснование"
                            android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                            android:textStyle="bold" />

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            app:cardBackgroundColor="@color/blue_50"
                            app:cardCornerRadius="8dp"
                            app:cardElevation="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="16dp">

                                <TextView
                                    android:id="@+id/scientificBackground"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="• Основано на кривой забывания Эббингауза\n• Интервалы рассчитаны по формуле SM-2\n• Эффективность подтверждена исследованиями\n• Адаптировано для разных типов памяти\n• Учитывает психологические особенности обучения"
                                    android:textAppearance="@style/TextAppearance.Material3.BodyMedium" />

                            </LinearLayout>

                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </ScrollView>

    </LinearLayout>

</FrameLayout>