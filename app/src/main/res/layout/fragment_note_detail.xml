<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Тулбар -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimarySurface"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:title="Редактирование конспекта"
        app:menu="@menu/menu_note_detail" />

    <!-- Прокручиваемый контейнер -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Поле названия - БЕЗ TextInputLayout для полной ширины -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Название конспекта *"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/titleInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/edit_text_background"
                android:imeOptions="actionNext"
                android:inputType="textCapSentences"
                android:maxLines="2"
                android:padding="16dp"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- Поле тегов - БЕЗ TextInputLayout -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Теги (через запятую)"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/tagsInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/edit_text_background"
                android:imeOptions="actionNext"
                android:maxLines="1"
                android:padding="16dp" />

            <!-- Поле содержания -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Содержание конспекта"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/contentInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/edit_text_background"
                android:gravity="top"
                android:inputType="textMultiLine|textCapSentences"
                android:minHeight="500dp"
                android:padding="16dp"
                android:scrollbars="vertical"
                android:textSize="16sp" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>