            <!-- Недавние сессии -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Недавние сессии"
                android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"
                android:layout_marginTop="24dp" />

            <!-- Состояние пустого списка -->
            <TextView
                android:id="@+id/emptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="40dp"
                android:text="Нет данных о сессиях\nНачните обучение, чтобы увидеть статистику"
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:visibility="gone" />

            <!-- Список сессий -->
            <LinearLayout
                android:id="@+id/recentSessionsList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone" />

            <!-- Debug информация (опционально) -->
            <TextView
                android:id="@+id/debugText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textSize="10sp"
                android:textColor="#666"
                android:visibility="gone" />

        </LinearLayout>

    </ScrollView>

    <!-- Кнопка очистки -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <Button
            android:id="@+id/clearStatsButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Очистить статистику"
            android:textColor="@color/red_500"
            style="@style/Widget.Material3.Button.OutlinedButton" />

    </LinearLayout>

</LinearLayout>