<!-- item_card.xml -->
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="4dp">

    <!-- FrameLayout для наложения overlay поверх всего -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- ОСНОВНОЙ КОНТЕЙНЕР С КОНТЕНТОМ -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <!-- ВСПЛЫВАЮЩАЯ ПОДСКАЗКА -->
            <include
                android:id="@+id/tooltipLayout"
                layout="@layout/tooltip_learning_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignTop="@+id/learnedIcon"
                android:layout_toStartOf="@+id/learnedIcon"
                android:layout_marginEnd="8dp"
                android:visibility="gone"
                tools:ignore="NotSibling" />

            <!-- ОСНОВНОЕ СОДЕРЖИМОЕ КАРТОЧКИ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Верхняя строка: вопрос и иконка выученности -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/cardFront"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_toStartOf="@+id/learnedIcon"
                        android:text="Вопрос"
                        android:textAppearance="?attr/textAppearanceHeadlineSmall"
                        android:textStyle="bold" />

                    <!-- Иконка выученности -->
                    <ImageView
                        android:id="@+id/learnedIcon"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_alignParentEnd="true"
                        android:layout_marginStart="8dp"
                        android:contentDescription="Статус изучения карточки"
                        android:src="@drawable/ic_learned"
                        android:visibility="gone"
                        android:padding="2dp" />

                </RelativeLayout>

                <!-- Разделитель -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E0E0E0"
                    android:layout_marginBottom="12dp" />

                <!-- Ответ -->
                <TextView
                    android:id="@+id/cardBack"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ответ"
                    android:textAppearance="?attr/textAppearanceBodyMedium" />

                <!-- Кнопка разворачивания -->
                <Button
                    android:id="@+id/expandButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Развернуть"
                    android:layout_gravity="end"
                    android:layout_marginTop="8dp"
                    android:visibility="gone"
                    android:background="?attr/selectableItemBackground"
                    android:textColor="?attr/colorPrimary" />

            </LinearLayout>

        </RelativeLayout>

        <!-- OVERLAY ДОЛЖЕН БЫТЬ В FrameLayout И НАКРЫВАТЬ ВСЮ КАРТОЧКУ -->
        <View
            android:id="@+id/selectionOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/selection_overlay"
            android:visibility="gone" />

    </FrameLayout>

</androidx.cardview.widget.CardView>