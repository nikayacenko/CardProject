<!-- item_card.xml -->
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="4dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- ОСНОВНОЙ КОНТЕЙНЕР С КОНТЕНТОМ -->
        <RelativeLayout
            android:id="@+id/cardContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <!-- ТАЙМЕР В ПРАВОМ ВЕРХНЕМ УГЛУ -->
            <LinearLayout
                android:id="@+id/timerLayout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_alignParentTop="true"
                android:layout_marginEnd="32dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/timer_background"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:visibility="gone">

<!--                <TextView-->
<!--                    android:id="@+id/timerIcon"-->
<!--                    android:layout_width="16dp"-->
<!--                    android:layout_height="16dp"-->
<!--                    android:textSize="12sp" />-->

                <TextView
                    android:id="@+id/timerText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="30 сек"
                    android:textSize="12sp"
                    android:textColor="@android:color/white"
                    android:layout_marginStart="4dp" />

            </LinearLayout>

            <!-- ВСПЛЫВАЮЩАЯ ПОДСКАЗКА -->
            <include
                android:id="@+id/tooltipLayout"
                layout="@layout/tooltip_learning_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignTop="@+id/learnedIcon"
                android:layout_toStartOf="@+id/learnedIcon"
                android:layout_marginEnd="8dp"
                android:visibility="gone"
                tools:ignore="NotSibling" />

            <!-- ОСНОВНОЕ СОДЕРЖИМОЕ КАРТОЧКИ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_below="@+id/timerLayout"
                android:layout_marginTop="4dp">

                <!-- Верхняя строка: вопрос -->
                <TextView
                    android:id="@+id/cardFront"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Вопрос"
                    android:textAppearance="?attr/textAppearanceHeadlineSmall"
                    android:textStyle="bold"
                    android:paddingEnd="32dp" />

                <!-- Разделитель -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E0E0E0"
                    android:layout_marginVertical="12dp" />

                <!-- Ответ -->
                <TextView
                    android:id="@+id/cardBack"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ответ"
                    android:textAppearance="?attr/textAppearanceBodyMedium" />

                <!-- Кнопка разворачивания -->
                <Button
                    android:id="@+id/expandButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Развернуть"
                    android:layout_gravity="end"
                    android:layout_marginTop="8dp"
                    android:visibility="gone"
                    android:background="?attr/selectableItemBackground"
                    android:textColor="?attr/colorPrimary" />

            </LinearLayout>

            <!-- Иконка выученности (перенесена в правый верхний угол) -->
            <ImageView
                android:id="@+id/learnedIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentEnd="true"
                android:layout_alignParentTop="true"
                android:layout_marginStart="8dp"
                android:contentDescription="Статус изучения карточки"
                android:src="@drawable/ic_learned"
                android:visibility="gone"
                android:padding="2dp" />

        </RelativeLayout>

        <!-- OVERLAY ДЛЯ ВЫДЕЛЕНИЯ -->
        <View
            android:id="@+id/selectionOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/selection_overlay"
            android:visibility="gone" />

    </FrameLayout>

</androidx.cardview.widget.CardView>